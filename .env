# ============================================================================
# Renji hackathon demo — copy this to ".env" and fill it in.
# ============================================================================

# 1) YOUR API KEY — create an account on the Renji site, copy your key.
RENJI_KEY=rh_yrlpftwp.hk6gs2ie.YWkuj_OAQsxCiz5HC92FTcOzxOI9YHe1

# 2) THE HOSTED HEART URL — our LIVE service (shown on the site).
#    The conscience lives there; this demo calls it directly. Nothing of the heart
#    runs on your machine. (Pre-filled to the live hackathon service.)
RENJI_URL=https://renji.guardianity.space

# 3) HOW YOUR MODEL CONNECTS:  local = run it in this folder · remote = your own GPU URL
VESSEL_MODE=local

# --- Mode A (VESSEL_MODE=local): your model runs HERE -----------------------
#     default is our abliterated model; swap for any instruct model (auto-calibrated).
HACK_MODEL_ID=TheUmbraWalker/gemma-4-E4B-it-2-heretic
HACK_DEVICE=cuda          # cpu | cuda   (use cuda on a GPU such as an A100)
HACK_DTYPE=auto          # auto | bfloat16 | float16 | float32

# --- Mode B (VESSEL_MODE=remote): your model runs on YOUR GPU; give its URL --
#     contract: POST {VESSEL_URL} {prompt,max_tokens,temperature} -> {text}
VESSEL_URL=
VESSEL_SECRET=

# shared
HACK_MAX_TOKENS=512
HF_TOKEN=                 # only needed for GATED models (e.g. Gemma)
HACK_PORT=8011
