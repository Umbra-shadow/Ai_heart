# ============================================================================
# Renji Research Lab — copy this to ".env" and fill it in.
# ============================================================================

# 1) GEMINI 3 — the brain. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
AGENT_MODEL=gemini-3-flash-preview     # Gemini 3 (list yours: GET /v1beta/models?key=KEY)

# 2) MONGODB — the hands + memory (the qualifying partner integration).
#    A connection string to a cluster. Free Atlas works: https://www.mongodb.com/atlas
MDB_MCP_CONNECTION_STRING=
# Which collection holds published findings (the grounding gate guards writes here).
FINDINGS_COLLECTION=findings

# 3) RENJI — the hosted conscience (the harm-check). Your key from the Renji site.
#    Without it, the guard still enforces GROUNDING + APPROVAL; only the harm-check
#    falls back to a local destructive-action backstop.
RENJI_KEY=
RENJI_URL=https://renji.guardianity.space

# 4) Demo control
#    AUTO_APPROVE=1 pre-grants the human "yes" for a hands-off demo.
#    (Grounding refusals and harm refusals STILL stand — only the approval pause lifts.)
AUTO_APPROVE=

# AI-Studio Gemini, not Vertex.
GOOGLE_GENAI_USE_VERTEXAI=FALSE
